# Copy to .env and fill in real values
APP_ENV=development
DEBUG=true
DATABASE_URL=postgresql+asyncpg://dupe:dupe@localhost:5432/dupe_platform
LOAD_SYNTHETIC_DATA=true

# [BLOCKED: A-WA] Meta Cloud API — pending WhatsApp Business Account verification
WHATSAPP_ACCESS_TOKEN=your_meta_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_API_VERSION=v19.0

# [BLOCKED: A-EMAIL] SendGrid — pending cobros@dupedesa.com domain setup
SENDGRID_API_KEY=your_sendgrid_key_here
EMAIL_FROM=cobros@dupedesa.com

# FX rate — set manually by management [A-FX]
USD_TO_DOP_RATE=58.50

# Payment plan approval [A-APPROVAL: set true if client chooses auto-activate]
PAYMENT_PLAN_AUTO_ACTIVATE=false

# Budget guard — block at 110% without mgmt override
BUDGET_GUARD_THRESHOLD_PCT=110.0
