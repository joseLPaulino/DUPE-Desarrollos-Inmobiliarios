# ══════════════════════════════════════════════════════════════════════════════
# DUPE Agentic Business Platform — Environment Configuration
# Copy this file to .env and fill in real values.
# .env is never committed to git (.gitignore excludes it).
# ══════════════════════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development         # development | staging | production
DEBUG=true
LOAD_SYNTHETIC_DATA=true    # set false in production

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# These vars are used by BOTH the 'db' Docker container AND the backend.
POSTGRES_USER=dupe
POSTGRES_PASSWORD=dupe
POSTGRES_DB=dupe_platform
POSTGRES_HOST=db            # 'db' = Docker service name; 'localhost' for local dev
POSTGRES_PORT=5432

# Assembled connection string (pydantic-settings reads this for the backend)
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ── WhatsApp ──────────────────────────────────────────────────────────────────
# [BLOCKED: A-WA] Meta Cloud API — WhatsApp Business Account verification 1–3 weeks
# Register at: https://business.facebook.com → WhatsApp → Get Started
WHATSAPP_ACCESS_TOKEN=SYNTHETIC_TOKEN
WHATSAPP_PHONE_NUMBER_ID=SYNTHETIC_PHONE_ID
WHATSAPP_API_VERSION=v19.0

# ── Email ─────────────────────────────────────────────────────────────────────
# [BLOCKED: A-EMAIL] SendGrid — domain cobros@dupedesa.com pending DNS setup
# Create API key at: https://app.sendgrid.com → Settings → API Keys
SENDGRID_API_KEY=SYNTHETIC_SENDGRID_KEY
EMAIL_FROM=cobros@dupedesa.com

# ── FX Rate ───────────────────────────────────────────────────────────────────
# [A-FX] USD → DOP rate — set manually by management; update when rate changes
USD_TO_DOP_RATE=58.50

# ── Business Rules ────────────────────────────────────────────────────────────
# [A-APPROVAL] false = payment plans need manual approval; true = auto-activate
PAYMENT_PLAN_AUTO_ACTIVATE=false
# Budget guard — block partida execution above this % without management override
BUDGET_GUARD_THRESHOLD_PCT=110.0
